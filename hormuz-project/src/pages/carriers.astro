---
import Layout from '../layouts/Layout.astro';
import { CARRIERS_DATA } from '../data/constants.js';
---

<Layout title="Carrier Suspension Status — Strait of Hormuz Shipping | HormuzWatch" description="Live tracking of major shipping carrier suspension status through the Strait of Hormuz. Maersk, MSC, CMA CGM, Hapag-Lloyd and more.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">Carrier Suspension Status</h1>
      <p class="text-slate-400">Major shipping carriers that have suspended Strait of Hormuz transits since February 28, 2026</p>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-800 bg-slate-800/50">
              <th class="px-6 py-4 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Carrier</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Country</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Fleet Size</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Status</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            {CARRIERS_DATA.map((carrier) => (
              <tr class="hover:bg-slate-800/50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-white">{carrier.name}</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-slate-300">{carrier.country}</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-slate-300">{carrier.fleet} vessels</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-500/20 text-red-400 border border-red-500/30">
                    {carrier.status}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-slate-400 max-w-md">{carrier.notes}</div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-8 bg-slate-900 border border-slate-800 rounded-xl p-6">
      <h2 class="text-xl font-semibold text-white mb-4">Carrier Impact Summary</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="p-4 bg-slate-800/50 rounded-lg">
          <div class="text-3xl font-bold text-red-400">{CARRIERS_DATA.filter(c => c.status === 'Suspended').length}</div>
          <div class="text-sm text-slate-400 mt-1">Carriers Suspended</div>
        </div>
        <div class="p-4 bg-slate-800/50 rounded-lg">
          <div class="text-3xl font-bold text-orange-400">{CARRIERS_DATA.reduce((sum, c) => sum + c.fleet, 0).toLocaleString()}+</div>
          <div class="text-sm text-slate-400 mt-1">Vessels Affected</div>
        </div>
        <div class="p-4 bg-slate-800/50 rounded-lg">
          <div class="text-3xl font-bold text-yellow-400">0</div>
          <div class="text-sm text-slate-400 mt-1">Active through Hormuz</div>
        </div>
      </div>
    </div>
  </div>
</Layout>
