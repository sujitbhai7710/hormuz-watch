---
import Layout from '../../layouts/Layout.astro';
import { BLOG_POSTS } from '../../data/constants.js';
---

<Layout title="Blog — Analysis & Updates on the Strait of Hormuz Crisis | HormuzWatch" description="In-depth analysis, diplomatic updates, and market insights on the Strait of Hormuz shipping disruption crisis.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <nav class="text-sm text-slate-400 mb-4">
        <a href="/" class="hover:text-white">Home</a> <span class="mx-2">›</span> <span class="text-white">Blog</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-2">Blog</h1>
      <p class="text-slate-400">Analysis, updates, and insights on the Strait of Hormuz crisis</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {BLOG_POSTS.map((post) => (
        <article class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden card-hover">
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-0.5 rounded text-xs font-medium bg-blue-500/20 text-blue-400 border border-blue-500/30">{post.category}</span>
              <span class="text-xs text-slate-500">{post.readingTime} min read</span>
            </div>
            <h2 class="text-lg font-semibold text-white mb-2 line-clamp-2">
              <a href={`/blog/${post.slug}`} class="hover:text-red-400 transition-colors">{post.title}</a>
            </h2>
            <p class="text-sm text-slate-400 line-clamp-3 mb-4">{post.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-slate-500">{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
              <a href={`/blog/${post.slug}`} class="text-sm text-red-400 hover:text-red-300 transition-colors">Read more →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
