---
import Layout from '../layouts/Layout.astro';
---

<Layout title="News — Latest Strait of Hormuz Crisis Updates | HormuzWatch" description="Latest news articles and updates on the Strait of Hormuz shipping crisis, oil markets, diplomacy, and global trade impact.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <nav class="text-sm text-slate-400 mb-4">
        <a href="/" class="hover:text-white">Home</a> <span class="mx-2">›</span> <span class="text-white">News</span>
      </nav>
      <h1 class="text-3xl font-bold text-white mb-2">Latest News</h1>
      <p class="text-slate-400">Aggregated news coverage of the Strait of Hormuz crisis</p>
    </div>

    <div id="news-container">
      <div class="text-center py-12 text-slate-500">Loading news...</div>
    </div>
  </div>
</Layout>

<script>
  async function loadNews() {
    try {
      const res = await fetch('/api/dashboard');
      const json = await res.json();
      if (!json.success || !json.data.news) return;
      
      const news = json.data.news;
      const container = document.getElementById('news-container');
      if (!container) return;
      
      container.innerHTML = `
        <div class="space-y-4">
          ${news.map((article: any) => `
            <a href="${article.url}" target="_blank" rel="noopener noreferrer" class="block bg-slate-900 border border-slate-800 rounded-xl p-6 card-hover">
              <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                <div class="flex-1">
                  <h2 class="text-lg font-semibold text-white mb-2 hover:text-red-400 transition-colors">${article.title}</h2>
                  <p class="text-sm text-slate-400 mb-3">${article.description}</p>
                  <div class="flex items-center gap-3">
                    <span class="px-2 py-0.5 rounded text-xs bg-slate-800 text-slate-300">${article.source}</span>
                    <span class="text-xs text-slate-500">${new Date(article.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
                  </div>
                </div>
                <svg class="w-5 h-5 text-slate-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </div>
            </a>
          `).join('')}
        </div>
      `;
    } catch(e) {
      document.getElementById('news-container')!.innerHTML = '<p class="text-red-400">Failed to load news.</p>';
    }
  }
  loadNews();
  setInterval(loadNews, 120000);
</script>
